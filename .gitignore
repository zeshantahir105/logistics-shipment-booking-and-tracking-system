# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ── Build output ───────────────────────────────────────────────────────────────
dist/
build/
backend/dist/
frontend/dist/
frontend/.vite/

# ── Environment files (never commit secrets) ───────────────────────────────────
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# ── Logs ───────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS / editor ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Docker local overrides ─────────────────────────────────────────────────────
docker-compose.override.yml

# ── MongoDB local data volume (if run outside Docker) ─────────────────────────
data/

# ── TypeScript incremental build cache ────────────────────────────────────────
*.tsbuildinfo
backend/*.tsbuildinfo

# ── Test coverage ──────────────────────────────────────────────────────────────
coverage/
backend/coverage/
frontend/coverage/
