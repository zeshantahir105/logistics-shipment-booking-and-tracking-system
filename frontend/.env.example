# Copy to .env and fill in your values.
# For Vercel deployment, set these in the Vercel project dashboard
# under Settings → Environment Variables — do NOT commit .env to git.

# ── API base URL ───────────────────────────────────────────────────────────────
# Local dev: leave empty — Vite proxies /api requests to localhost:4000
# VITE_API_URL=
#
# Production: set this to your deployed backend Vercel URL (no trailing slash)
# e.g. https://logistics-backend.vercel.app
VITE_API_URL=https://<your-backend>.vercel.app
