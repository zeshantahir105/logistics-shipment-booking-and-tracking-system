# Copy to .env and fill in your values.
# For Vercel deployment, set these in the Vercel project dashboard
# under Settings → Environment Variables — do NOT commit .env to git.

# ── MongoDB ────────────────────────────────────────────────────────────────────
# Local dev (Docker Compose — single-node replica set required for transactions):
# MONGO_URI=mongodb://127.0.0.1:27017/logistics?replicaSet=rs0
#
# Production — use a MongoDB Atlas free-tier cluster:
# 1. Create a cluster at https://cloud.mongodb.com
# 2. Click Connect → Drivers → copy the connection string
# 3. Replace <password> and set the database name to "logistics"
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/logistics?retryWrites=true&w=majority

# ── Server ─────────────────────────────────────────────────────────────────────
# Vercel sets PORT automatically — only needed for local / Docker runs
PORT=4000

# ── CORS ───────────────────────────────────────────────────────────────────────
# Local dev: the Vite dev server origin
# CORS_ORIGIN=http://localhost:5173
#
# Production: set this to your deployed frontend Vercel URL, e.g.
# CORS_ORIGIN=https://logistics-frontend.vercel.app
CORS_ORIGIN=*

# ── Node env ───────────────────────────────────────────────────────────────────
NODE_ENV=production
